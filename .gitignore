# Delphi gitignore - optimized for DX.Comply
# Source: https://github.com/omonien/DelphiStandards/blob/master/Delphi%20GitIgnore.txt

# =========================
# Compiled files
# =========================
*.dcu
*.dcp
*.bpl
*.exe
*.dll
*.res
!src/DX.Comply.IDE.Splash.res
*.rsm
*.map
*.tvsconfig
*.drc
*.lib
*.a
*.o
*.obj

# =========================
# IDE files
# =========================
*.dsk
*.local
*.identcache
*.projdata
*.tvsconfig
*.stat
*.groupproj.local
*.dproj.local

# Visual Studio Code Delphi test-adapter cache (SQLite, kept open while VS Code runs)
*.vsdcache.db
*.vsdcache.db-shm
*.vsdcache.db-wal
*.vsdcache.status

# History and backup files
__history/
__recovery/
*.bak
*.orig
*~

# =========================
# Build output
# =========================
# Ignore build output but track the build script itself
build/*
!build/DelphiBuildDPROJ.ps1
!build/.gitkeep
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
Win32/
Win64/

# =========================
# Packages
# =========================
*.bpl
*.dcp

# =========================
# VS Code
# =========================
.vscode/
*.code-workspace

# =========================
# macOS
# =========================
.DS_Store
.AppleDouble
.LSOverride
._*

# =========================
# Windows
# =========================
Thumbs.db
ehthumbs.db
Desktop.ini

# =========================
# Test results
# =========================
*.xml
TestResults/

# =========================
# NuGet (if used)
# =========================
packages/
.nuget/

# =========================
# Artifacts
# =========================
*.zip
*.7z
*.rar

# =========================
# GNU Global tags
# =========================
GPATH
GRTAGS
GTAGS

# =========================
# SBOM generated output
# =========================
**/bom.json
**/bom.report.html
**/bom.report.md
"*.diag.log"
"*.f*.dproj"
"msbuild-preprocess.log"

# GSD planning (local only)
.planning/

# Claude Code (worktrees and other Claude working files)
.claude/
